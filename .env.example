# Comma-separated absolute paths for fs_* tools. Example: /home/you/projects  (dostosuj; stary przykład: /home/jump)
MCP_ALLOWED_ROOTS=

# Optional: default Microsoft Graph OAuth access token (delegated). Per-call override: pass graph_access_token on microsoft_* tools.
# MCP_GRAPH_ACCESS_TOKEN=

MCP_MAX_READ_BYTES=1048576
MCP_MAX_WRITE_BYTES=2097152
MCP_SHELL_TIMEOUT_SEC=8
